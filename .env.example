# Copy this file to .env and fill in your values.
# .env is gitignored. .env.example is tracked.

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
# LOG_FORMAT=dev        # "dev" (coloured, human-readable) | "json" (production)

# ---------------------------------------------------------------------------
# Database (SQLite)
# ---------------------------------------------------------------------------
DB_PATH=afterhours.db
# DB_PATH=:memory:      # in-memory, useful for quick test runs

# ---------------------------------------------------------------------------
# Kraken feed (PRIMARY — no auth required for public data)
# ---------------------------------------------------------------------------
KRAKEN_PRODUCTS=["BTC-USD","ETH-USD"]
# KRAKEN_WS_URL=wss://ws.kraken.com/v2    # default, no need to set

# ---------------------------------------------------------------------------
# Coinbase feed (available but not started until API keys are configured)
# ---------------------------------------------------------------------------
# COINBASE_PRODUCTS=["BTC-USD","ETH-USD"]
# COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com/ws

# API keys — READ-ONLY, WITHDRAWAL-DISABLED only. Never commit real values.
# See docs/adr/003-api-key-security.md
# COINBASE_API_KEY=
# COINBASE_API_SECRET=

# ---------------------------------------------------------------------------
# Future: Postgres (Phase 5+)
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/afterhours

# ---------------------------------------------------------------------------
# Future: Redis (Phase 5+)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
