# Copy this file to .env and fill in your values.
# .env is gitignored. .env.example is tracked.

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
# LOG_FORMAT=dev        # "dev" (coloured, human-readable) | "json" (production)

# ---------------------------------------------------------------------------
# Database (SQLite)
# ---------------------------------------------------------------------------
DB_PATH=afterhours.db
# DB_PATH=:memory:      # in-memory, useful for quick test runs

# ---------------------------------------------------------------------------
# Kraken feed (PRIMARY — no auth required for public data)
# ---------------------------------------------------------------------------
KRAKEN_PRODUCTS=["BTC-USD","ETH-USD"]
# KRAKEN_WS_URL=wss://ws.kraken.com/v2    # default, no need to set

# ---------------------------------------------------------------------------
# Coinbase feed (available but not started until API keys are configured)
# ---------------------------------------------------------------------------
# COINBASE_PRODUCTS=["BTC-USD","ETH-USD"]
# COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com/ws

# API keys — READ-ONLY, WITHDRAWAL-DISABLED only. Never commit real values.
# See docs/adr/003-api-key-security.md
# COINBASE_API_KEY=
# COINBASE_API_SECRET=

# ---------------------------------------------------------------------------
# Equity feed (REST polling — requires free API key from alpaca or polygon)
# ---------------------------------------------------------------------------
# EQUITY_FEED_PROVIDER=alpaca          # "alpaca" (default) | "polygon" | "none"
# EQUITY_FEED_API_KEY=                 # Alpaca: key ID  |  Polygon: API key
# EQUITY_FEED_API_SECRET=              # Alpaca only; leave blank for polygon
# EQUITY_POLL_INTERVAL_SECONDS=60      # polling cadence in seconds (default 60)

# ---------------------------------------------------------------------------
# News feed (RSS — any public RSS/Atom URL, no API key required)
# ---------------------------------------------------------------------------
# Crypto (defaults)
# NEWS_FEED_URLS=["https://www.coindesk.com/arc/outboundfeeds/rss/","https://cointelegraph.com/rss","https://finance.yahoo.com/rss/topstories","https://feeds.content.dowjones.io/public/rss/mw_topstories","https://www.nasdaq.com/feed/rssoutbound?category=Markets","https://www.benzinga.com/feed","https://www.investing.com/rss/news.rss","https://www.fool.com/feeds/index.aspx","https://www.marketbeat.com/feed/"]

#
# Equity / general market (add to the list above as needed; verify URLs are still active):
#   Yahoo Finance top stories:  https://finance.yahoo.com/rss/topstories
#   MarketWatch top stories:    https://feeds.content.dowjones.io/public/rss/mw_topstories
#
# NEWS_POLL_INTERVAL_SECONDS=300

# ---------------------------------------------------------------------------
# Insider transactions feed (SEC EDGAR Form 4 — Phase 6A alt-data, no API key)
# ---------------------------------------------------------------------------
# SEC fair-access policy requires a descriptive User-Agent with contact info;
# a generic UA gets a 403. Set this to your name/app + contact email.
# INSIDER_USER_AGENT=YourName YourApp your-email@example.com
# INSIDER_MIN_TRANSACTION_USD=100000   # materiality floor for open-market buys/sells
# INSIDER_POLL_INTERVAL_SECONDS=300
# INSIDER_CURRENT_URL=https://www.sec.gov/cgi-bin/browse-edgar?action=getcurrent&type=4&owner=include&count=100&output=atom

# ---------------------------------------------------------------------------
# Congressional trades feed (Quiver Quantitative — Phase 6A alt-data)
# ---------------------------------------------------------------------------
# DEFERRED/DORMANT (2026-06-14): Quiver dropped its free API tier ($30/mo min,
# personal-use only) and the free JSON mirrors went dark. The feed is wired but
# no-ops without a token, so leaving this blank costs nothing. See
# docs/phase-6a-limitations.md § Congress to reactivate (paid token or a new
# free source). Without a token the feed no-ops — graceful degradation.
# QUIVER_API_TOKEN=
# QUIVER_MIN_AMOUNT_USD=50000          # floor on the lower bound of the disclosed range
# QUIVER_POLL_INTERVAL_SECONDS=3600    # congress data is a daily batch; hourly is generous
# QUIVER_BASE_URL=https://api.quiverquant.com/beta/live/congresstrading

# ---------------------------------------------------------------------------
# Government-exposure feed: lobbying + contracts (Phase 6A alt-data, free)
# ---------------------------------------------------------------------------
# Queries Senate LDA (lobbying) + USASpending (contracts) per watched EQUITY.
# Both are free; USASpending needs no key. The LDA key is optional and only
# raises the anonymous rate limit. Inert until the watchlist holds equities.
# SEC requires a descriptive User-Agent for the ticker→name map fetch.
# GOVEXP_USER_AGENT=YourName YourApp your-email@example.com
# GOVEXP_LDA_API_KEY=                  # optional; register free at lda.senate.gov
# GOVEXP_MIN_LOBBYING_USD=50000
# GOVEXP_MIN_CONTRACT_USD=1000000
# GOVEXP_LOOKBACK_DAYS=30              # only emit filings/awards disclosed within this window
# GOVEXP_POLL_INTERVAL_SECONDS=21600  # 6h — lobbying/contracts are low frequency

# ---------------------------------------------------------------------------
# Supply-chain feed: 10-K customer concentration (Phase 6A alt-data, free)
# ---------------------------------------------------------------------------
# Extracts "Customer X = N% of revenue" disclosures from each watched EQUITY's
# latest 10-K (SEC EDGAR, no key). Public filings only. Inert without equities.
# SEC requires a descriptive User-Agent.
# SUPPLYCHAIN_USER_AGENT=YourName YourApp your-email@example.com
# SUPPLYCHAIN_MIN_REVENUE_PCT=10       # customer-concentration materiality threshold (%)
# SUPPLYCHAIN_LOOKBACK_DAYS=400        # only the latest annual 10-K
# SUPPLYCHAIN_POLL_INTERVAL_SECONDS=604800  # weekly — 10-Ks are annual

# ---------------------------------------------------------------------------
# Price alerts (tick → signal.created)
# ---------------------------------------------------------------------------
# ALERT_PRICE_MOVE_PCT_THRESHOLD=0.5   # % move within window that fires an alert
# ALERT_PRICE_MOVE_WINDOW_MINUTES=15   # rolling window for the % move calculation
# ALERT_ALERT_COOLDOWN_MINUTES=10      # min gap between repeat alerts of same type
# Defaults above suit crypto; with many equities raise the threshold (~1.5)
# and cooldown (~30) so intraday wiggles don't flood the signal feed.

# ---------------------------------------------------------------------------
# LLM provider (Phase 2+)
# ---------------------------------------------------------------------------
# LLM_PROVIDER=ollama    # ollama (default) | anthropic | openai | groq | mistral | openrouter
# LLM_MODEL=            # leave blank to use per-provider default (see reasoning/llm/settings.py)
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=1024
# LLM_OLLAMA_BASE_URL=http://localhost:11434

# Paid providers
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Free-tier providers (no credit card required to start)
# GROQ_API_KEY=         # free: 14,400 req/day — default model: llama-3.3-70b-versatile
# MISTRAL_API_KEY=      # free: 1B tokens/month — default model: mistral-small-latest
# OPENROUTER_API_KEY=   # free: 50 req/day (1,000/day after $10) — default: llama-3.3-70b-instruct:free

# Thesis generation tuning
# THESIS_MIN_SIGNALS_TO_TRIGGER=3
# THESIS_SIGNAL_WINDOW_MINUTES=15
# THESIS_COOLDOWN_MINUTES=60
# THESIS_EXPIRY_HOURS=8

# ---------------------------------------------------------------------------
# Risk engine (Phase 3+)
# ---------------------------------------------------------------------------
# RISK_MAX_POSITION_PCT=0.05        # max % of portfolio in any single position
# RISK_MAX_TRADE_LOSS_PCT=0.02      # max acceptable loss per trade (2% default)
# RISK_STOP_LOSS_PCT=0.03           # stop price distance from entry (3% default)
# RISK_MAX_OPEN_POSITIONS=5         # circuit breaker on total open positions; each is
#                                   # capped at MAX_POSITION_PCT, so N positions = N*pct
#                                   # deployed. Higher = more calibration samples in paper,
#                                   # but the engine has no correlation/sector cap — raising
#                                   # this can stack correlated names into one effective bet.
# RISK_MAX_DAILY_LOSS_PCT=0.05      # daily loss circuit breaker (5% default)

# ---------------------------------------------------------------------------
# Portfolio / paper trading (Phase 3+)
# ---------------------------------------------------------------------------
# PORTFOLIO_INITIAL_CASH=10000.00   # simulated starting cash
# PORTFOLIO_SLIPPAGE_PCT=0.001      # 0.1% fill slippage simulation
# PORTFOLIO_FEE_PCT=0.001           # 0.1% simulated fee per fill

# ---------------------------------------------------------------------------
# Calibration / outcome resolution (Phase 4+)
# ---------------------------------------------------------------------------
# Horizon → resolution duration (when a decision's prediction is scored)
# CALIBRATION_HORIZON_SCALP_MINUTES=30
# CALIBRATION_HORIZON_INTRADAY_HOURS=4
# CALIBRATION_HORIZON_SWING_DAYS=3
# CALIBRATION_HORIZON_POSITION_DAYS=21
# CALIBRATION_ECE_BUCKETS=10           # confidence buckets for ECE / reliability table

# Autonomy graduation gates (PLANNING Appendix B, Balanced profile)
# CALIBRATION_GATE_OBSERVE_MIN_SAMPLE=50
# CALIBRATION_GATE_OBSERVE_MAX_ECE=0.18
# CALIBRATION_GATE_PAPER_MIN_SAMPLE=100
# CALIBRATION_GATE_PAPER_MIN_DAYS=14
# CALIBRATION_GATE_PAPER_MAX_ECE=0.12

# ---------------------------------------------------------------------------
# Future: Postgres (Phase 6+)
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/afterhours

# ---------------------------------------------------------------------------
# Future: Redis (Phase 6+)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
