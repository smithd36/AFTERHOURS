# Copy this file to .env and fill in your values.
# .env is gitignored. .env.example is tracked.

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
# LOG_FORMAT=dev        # "dev" (coloured, human-readable) | "json" (production)

# ---------------------------------------------------------------------------
# Database (SQLite)
# ---------------------------------------------------------------------------
DB_PATH=afterhours.db
# DB_PATH=:memory:      # in-memory, useful for quick test runs

# ---------------------------------------------------------------------------
# Coinbase feed
# ---------------------------------------------------------------------------
# Products to subscribe to (JSON array format)
COINBASE_PRODUCTS=["BTC-USD","ETH-USD"]
# COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com   # default, no need to set

# API keys — only needed for authenticated (private) channels.
# For public market data (Phase 0–3) these are NOT required.
# Use READ-ONLY, WITHDRAWAL-DISABLED keys only. Never commit real values.
# COINBASE_API_KEY=
# COINBASE_API_SECRET=

# ---------------------------------------------------------------------------
# Future: Postgres (Phase 5+)
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/afterhours

# ---------------------------------------------------------------------------
# Future: Redis (Phase 5+)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
